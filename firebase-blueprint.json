{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Climate equipment item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "power": { "type": "string" },
        "area": { "type": "string" },
        "description": { "type": "string" },
        "modelUrl": { "type": "string" }
      },
      "required": ["id", "name", "price"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["items", "total", "status", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of climate products"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer purchase orders"
    }
  }
}
